{
  "name": "plansketch-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"tsx server/index.ts\" \"vite\"",
    "dev:client": "vite",
    "dev:server": "tsx server/index.ts",
    "build": "tsc -b && vite build",
    "preview": "concurrently \"node dist-server/index.js\" \"vite preview\"",
    "preview:client": "vite preview",
    "preview:server": "node dist-server/index.js",
    "start": "node dist-server/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.3",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^5.4.17"
  }
}
