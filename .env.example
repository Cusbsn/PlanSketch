PORT=8787

# mock | real
PLANSKETCH_PROVIDER_MODE=mock
PLANSKETCH_FALLBACK_TO_MOCK=true

# image understanding
PLANSKETCH_IMAGE_UNDERSTANDING_PROVIDER=mock
PLANSKETCH_IMAGE_UNDERSTANDING_BASE_URL=https://api.openai.com/
PLANSKETCH_IMAGE_UNDERSTANDING_API_KEY=your-image-understanding-key
PLANSKETCH_IMAGE_UNDERSTANDING_MODEL=gpt-4.1-mini
PLANSKETCH_IMAGE_UNDERSTANDING_TIMEOUT_MS=20000

# prompt builder
PLANSKETCH_PROMPT_BUILDER_PROVIDER=mock
PLANSKETCH_PROMPT_BUILDER_BASE_URL=https://your-provider.example.com/
PLANSKETCH_PROMPT_BUILDER_API_KEY=your-prompt-builder-key
PLANSKETCH_PROMPT_BUILDER_MODEL=text-model-id
PLANSKETCH_PROMPT_BUILDER_TIMEOUT_MS=20000

# image generation
PLANSKETCH_IMAGE_GENERATION_PROVIDER=mock
PLANSKETCH_IMAGE_GENERATION_BASE_URL=https://your-provider.example.com/
PLANSKETCH_IMAGE_GENERATION_API_KEY=your-image-generation-key
PLANSKETCH_IMAGE_GENERATION_MODEL=image-model-id
PLANSKETCH_IMAGE_GENERATION_TIMEOUT_MS=30000
